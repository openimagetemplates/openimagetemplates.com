{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openimagetemplates.com/open-image-template.schema.json",
  "title": "Open Image Template",
  "description": "A portable template format for reusable AI image generation prompts.",
  "type": "object",
  "required": [
    "standard",
    "schema_version",
    "id",
    "title",
    "description",
    "prompt",
    "slots",
    "suggested_models",
    "examples",
    "license"
  ],
  "properties": {
    "standard": {
      "const": "open-image-template"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string"
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "negative_prompt": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "label", "example"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "label": {
            "type": "string"
          },
          "example": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "suggested_models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role"],
        "properties": {
          "id": {
            "type": "string"
          },
          "role": {
            "enum": ["suggested", "compatible", "tested"]
          }
        },
        "additionalProperties": false
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["image_url", "generated_at", "schema_version"],
        "properties": {
          "image_url": {
            "type": "string"
          },
          "generated_at": {
            "type": "string",
            "format": "date"
          },
          "schema_version": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "creator": {
      "type": "string"
    },
    "license": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
